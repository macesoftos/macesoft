API_PORT=3001
APP_ORIGIN=https://app.example.com
ENABLE_DEMO_ACCOUNTS=false

# 32+ random characters used to encrypt FaceTrack biometric descriptors at rest.
# Required in production. Rotate only through a planned biometric re-enrollment.
FACETRACK_ENCRYPTION_KEY=

# Supabase Postgres. Use the session pooler for the running API and the direct
# connection for Prisma migrations. Never expose either value to Vite/client code.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Generic lead intake. Generate long, independent random values for each secret.
LEADS_WEBHOOK_SECRET=
LEADS_API_KEY=
GOOGLE_ADS_WEBHOOK_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Facebook / Meta Lead Ads. The verify token is a random value you create and
# enter in both this file and the Meta App webhook configuration.
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v24.0

# Set to true to test the Marketing send flow without contacting Twilio or SMTP.
MARKETING_DRY_RUN=false
MAX_MARKETING_SENDS=500

# SMS delivery via Twilio. Use either TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
SMS_DEFAULT_COUNTRY_CODE=63

# Email delivery via any SMTP account.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MACE by Dr. Mace <no-reply@example.com>"
