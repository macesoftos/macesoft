{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2023",
    "types": ["node", "react", "react-dom"]
  },
  "include": ["server/**/*", "scripts/**/*", "src/lib/**/*.js", "src/data.js", "vite.config.js"],
  "exclude": ["dist", "node_modules", "tmp"]
}
