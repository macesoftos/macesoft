{
  "name": "mace-clinic-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,VITE -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node server/api-smoke-test.js",
    "db:generate": "prisma generate",
    "db:push": "node server/init-db.js",
    "db:seed": "node server/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "playwright": "^1.61.1",
    "prisma": "^7.8.0"
  }
}
