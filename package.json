{
  "name": "mace-clinic-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "concurrently -k -n API,VITE -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "start": "prisma migrate deploy && node server/index.js",
    "start:production": "prisma migrate deploy && node server/index.js",
    "postinstall": "prisma generate",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test server/*.test.js",
    "test:integration": "node server/api-smoke-test.js",
    "test:facetrack": "node --test server/facetrackAttendance.test.js",
    "test:security": "node --test server/accessControl.test.js server/apiBoundary.test.js server/productionConfig.test.js",
    "test:e2e": "playwright test",
    "test:release": "node scripts/isolated-release-test.mjs",
    "backup": "node scripts/backup.mjs",
    "backup:verify": "node scripts/verify-backup.mjs",
    "restore": "node scripts/restore.mjs",
    "readiness": "node scripts/readiness.mjs",
    "bootstrap:owner": "node scripts/create-owner.mjs",
    "assets:cleanup": "node scripts/cleanup-assets.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node server/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "face-api.js": "0.22.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.468.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "read-excel-file": "^9.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2"
  }
}
